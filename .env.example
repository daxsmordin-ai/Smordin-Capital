# Postgres connection string (Neon, Supabase, Railway, local Docker, etc.)
# Neon example: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/pf_news?schema=public"

# Optional: NewsAPI.org key. If unset, the NewsAPI provider is skipped.
NEWS_API_KEY=""

# Optional: Marketaux key for finance-tagged news (skipped if empty).
MARKETAUX_API_KEY=""

# Optional: shared secret to protect /api/ingest from public abuse.
# When set, requests must include `Authorization: Bearer <token>` or `?token=<token>`.
INGEST_TOKEN=""

# Optional: cap on articles persisted per ingest run (per source).
INGEST_MAX_PER_SOURCE="50"
